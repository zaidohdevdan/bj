{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "./dist",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@ephemeral/shared": ["../../packages/shared/src/index"],
      "@ephemeral/shared/*": ["../../packages/shared/src/*"],
      "@ephemeral/shared/schemas": ["../../packages/shared/src/schemas/index"],
      "@ephemeral/shared/types": ["../../packages/shared/src/types/index"],
      
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*"]
}
