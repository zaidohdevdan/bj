{
  "name": "ephemeral-chat-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -c \"cyan,magenta\" \"npm run dev -w @ephemeral/api\" \"npm run dev -w web\"",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
